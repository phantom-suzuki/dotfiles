# direnv: このリポジトリで Codex を work アカウント（~/.codex-work）に切り替える。
#
# 使い方:
#   1) このファイルをリポジトリ root に `.envrc` としてコピー
#        cp ~/.local/share/chezmoi/docs/templates/codex-work.envrc .envrc
#   2) `direnv allow`
#   3) .envrc はコミットしない（zsh 関数 `codex-use-work` を使えば自動で git-exclude される）
#
# ※ 共有リポでこのファイルをコミットすると、~/.codex-work を持たない同僚の
#    codex に影響する。必ず .git/info/exclude か global gitignore で除外すること。
export CODEX_HOME=$HOME/.codex-work
