# Ghostty configuration
# Mirrors the WezTerm setup (Iceberg phantom theme, Source Han Code JP)
# Reference: ghostty.org/docs/config/reference

# --- Font ---
font-family = Source Han Code JP
font-family = Symbols Nerd Font Mono
font-size = 14

# --- Window ---
window-padding-x = 8
window-padding-y = 8
window-padding-balance = true
window-save-state = always
macos-titlebar-style = transparent
macos-option-as-alt = true

# --- Background / transparency ---
# WezTerm composites a background image (hsb brightness 0.15) under a
# #161821 dark overlay (opacity 0.75) on an opaque window. We mirror
# that with an opaque window + image overlay (option A from the
# WezTerm-parity discussion). Adjust background-image-opacity in
# 0.18–0.25 if the image feels too faint or too strong.
background-opacity = 1.0
background-image = {{ .chezmoi.homeDir }}/.config/wezterm/backgrounds/nixie-tube.png
background-image-opacity = 0.20
background-image-position = center
background-image-fit = cover
background-image-repeat = false

# --- Iceberg phantom colors ---
background = #161821
foreground = #c5c8d0
cursor-color = #c5c8d0
cursor-text = #161821
selection-background = #272b41
selection-foreground = #c5c8d0

# ANSI 0-7
palette = 0=#151820
palette = 1=#e17878
palette = 2=#b3bd82
palette = 3=#e1a378
palette = 4=#83a0c5
palette = 5=#a092c7
palette = 6=#89b8c1
palette = 7=#c5c8d0
# Bright 8-15
palette = 8=#6a7089
palette = 9=#e98989
palette = 10=#c0c98e
palette = 11=#e9b189
palette = 12=#91abd0
palette = 13=#aca0d3
palette = 14=#95c4ce
palette = 15=#d2d3de

# --- Cursor ---
cursor-style = block
cursor-style-blink = false

# --- Shell integration ---
# Ghostty auto-detects zsh; explicit declaration just to be safe.
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# --- Misc ---
copy-on-select = false
mouse-hide-while-typing = true
confirm-close-surface = false

# --- Keybindings (mirror WezTerm setup where possible) ---
# WezTerm features that don't map: Lua statusbar, format-tab-title,
# workspace mux, resurrect, smart-splits Vim auto-detect (use tmux).

# Pane navigation: Ctrl+hjkl
# (Vim-aware behavior comes from tmux + smart-splits.nvim, not Ghostty.)
keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:down
keybind = ctrl+k=goto_split:up
keybind = ctrl+l=goto_split:right

# Pane resize: Alt+hjkl (one-shot, repeats while held)
keybind = alt+h=resize_split:left,3
keybind = alt+j=resize_split:down,3
keybind = alt+k=resize_split:up,3
keybind = alt+l=resize_split:right,3

# Tabs: Cmd+T new, Cmd+W close (Cmd+1-9 / Ctrl+Tab use defaults)
keybind = super+t=new_tab
keybind = super+w=close_surface

# Fullscreen / search / palette / reload — match WezTerm Ctrl+Shift+ chords
keybind = ctrl+shift+enter=toggle_fullscreen
keybind = ctrl+shift+f=start_search
keybind = ctrl+shift+p=toggle_command_palette
keybind = ctrl+shift+r=reload_config

# Font size — match WezTerm Ctrl chords (Cmd defaults stay active too)
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+plus=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+0=reset_font_size

# Leader = Ctrl+Q (chord). WezTerm's leader-driven pane/tab ops.
# d = vertical-stacked split, r = side-by-side split (matches WezTerm names).
keybind = ctrl+q>d=new_split:down
keybind = ctrl+q>r=new_split:right
keybind = ctrl+q>x=close_surface
keybind = ctrl+q>z=toggle_split_zoom
keybind = ctrl+q>[=move_tab:-1
keybind = ctrl+q>]=move_tab:1
keybind = ctrl+q>e=equalize_splits

# Tab title: prompt to rename (replaces WezTerm's Lua format-tab-title)
keybind = ctrl+q>n=prompt_tab_title
